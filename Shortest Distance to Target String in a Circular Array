class Solution:
    def closestTarget(self, words, target, startIndex):
        n = len(words)
        ans = float('inf')

        for i in range(n):
            if words[i] == target:
                direct = abs(startIndex - i)
                circular = n - direct
                ans = min(ans, min(direct, circular))
        
        return ans if ans != float('inf') else -1
