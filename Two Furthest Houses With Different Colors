class Solution:
    def maxDistance(self, colors: List[int]) -> int:
        n = len(colors)
        result = 0
        for i in range(n - 1, 0, -1):
            if colors[i] != colors[0]:
                result = max(result, i)
                break
        for i in range(n - 1):
            if colors[i] != colors[n - 1]:
                result = max(result, n - 1 - i)
                break
        return result
